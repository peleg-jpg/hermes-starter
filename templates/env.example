# Secrets for ONE Hermes brain. Copied to <brain>/.env by new-brain.sh.
# Fill in, then: cd <brain folder> && docker compose restart
# This file is gitignored at the brain folder; NEVER commit a filled-in copy.
#
# ── Model provider (pick ONE; this is what the brain thinks with) ─────────
# Easiest path: drop an API key here and it just works. The seeded config
# defaults to the openai-codex OAuth provider; to use a raw key instead,
# run `<brain>` once and pick your provider in the setup wizard, or edit
# data/config.yaml (model.provider / model.default).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
#
# ── Transcription + vision aux ───────────────────────────────────────────
# Voice-message transcription uses OpenAI whisper-1 (config: stt). If your
# main model is NOT OpenAI, still set this so transcription works:
# OPENAI_API_KEY=
#
# ── MCP servers ──────────────────────────────────────────────────────────
# The seeded config wires the Apify MCP (web scraping/social) via this token.
# Get one at https://console.apify.com/account/integrations
# APIFY_TOKEN=
#
# ── Messaging (fill in only what this brain answers on) ───────────────────
# Each brain needs its OWN bot token. Reusing another brain's Telegram token
# makes the second poller 409 and refuse to start.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=        # comma-separated numeric user ids that may talk to it
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
#
# ── Optional local dashboard (off unless set) ────────────────────────────
# HERMES_DASHBOARD=1
# HERMES_DASHBOARD_HOST=127.0.0.1
# HERMES_DASHBOARD_PORT=9120
